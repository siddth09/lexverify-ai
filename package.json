import React, { useState, useEffect, useRef } from 'react';
import { 
  ShieldCheck, 
  AlertTriangle, 
  FileText, 
  CheckCircle, 
  XCircle, 
  Loader2, 
  Scale,
  Search,
  ChevronRight,
  BookOpen,
  Info,
  Key,
  Settings,
  Image as ImageIcon,
  Upload,
  Type,
  FileCode
} from 'lucide-react';

const SAMPLES = [
  {
    title: "Onerous & Clawback Sample",
    type: "High Risk",
    text: `EMPLOYMENT & INCENTIVE AGREEMENT
1. Bonuses: The Employee is eligible for a $50,000 performance bonus.
2. Clawback Provision: If the Employee resigns for any reason within 24 months of receiving any bonus, the Company reserves the absolute right to claw back 100% of the gross bonus amount, which shall be deducted from the final paycheck or recovered via legal action.
3. Onerous Payment: All expense reimbursements will be processed 180 days after the end of the fiscal year in which the expense was incurred.
4. Prohibited Restraint: Employee is strictly prohibited from working for any company in the same industry globally for a period of 5 years after termination, regardless of the reason for leaving.`
  },
  {
    title: "Standard NDA",
    type: "Safe",
    text: `MUTUAL NON-DISCLOSURE AGREEMENT
This Agreement is entered into as of October 24, 2023 (the "Effective Date") between TechCorp Inc. and Innovate LLC.
1. Confidential Information: Parties agree to protect proprietary data disclosed during the term.
2. Termination: This agreement remains in effect for three (3) years. Either party may terminate with 30 days written notice.
3. Governing Law: This agreement is governed by the laws of the State of Delaware.`
  },
  {
    title: "High-Risk Service Contract",
    type: "Risky",
    text: `SERVICE LEVEL AGREEMENT
Liability: Provider shall have no liability for any damages, direct or indirect, arising from the service. Client waives all rights to sue for negligence.
Changes: Provider reserves the right to make unilateral changes to the pricing and terms at any time without prior notice or consent.
Duration: This contract is forever binding and cannot be terminated by the client for the first 10 years of the relationship.`
  },
  {
    title: "Incomplete MOU",
    type: "Missing Info",
    text: `MEMORANDUM OF UNDERSTANDING
The parties agree to work together on the Project. 
The parties will keep information private. 
Signed, 
Party A`
  }
];

const App = () => {
  const [activeTab, setActiveTab] = useState('upload');
  const [docText, setDocText] = useState('');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [results, setResults] = useState(null);
  const [error, setError] = useState(null);
  
  // File Processing States
  const [isProcessing, setIsProcessing] = useState(false);
  const [processProgress, setProcessProgress] = useState(0);
  const fileInputRef = useRef(null);

  // API Key State
  const [apiKey, setApiKey] = useState('');
  const [showKeyInput, setShowKeyInput] = useState(false);

  useEffect(() => {
    const savedKey = localStorage.getItem('lexverify_api_key');
    if (savedKey) setApiKey(savedKey);
    else setShowKeyInput(true);
    
    // Load OCR and PDF processing libraries
    const loadScript = (src) => {
      return new Promise((resolve) => {
        const script = document.createElement('script');
        script.src = src;
        script.onload = resolve;
        document.body.appendChild(script);
      });
    };

    Promise.all([
      loadScript('https://unpkg.com/tesseract.js@v4.0.1/dist/tesseract.min.js'),
      loadScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js')
    ]).then(() => {
      if (window.pdfjsLib) {
        window.pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';
      }
    });
  }, []);

  const saveApiKey = (key) => {
    setApiKey(key);
    localStorage.setItem('lexverify_api_key', key);
    setShowKeyInput(false);
  };

  const handleFileUpload = async (e) => {
    const file = e.target.files[0];
    if (!file) return;

    setIsProcessing(true);
    setProcessProgress(0);
    setError(null);

    try {
      if (file.type === 'application/pdf') {
        // PDF Processing
        const reader = new FileReader();
        reader.onload = async () => {
          const typedarray = new Uint8Array(reader.result);
          const pdf = await window.pdfjsLib.getDocument(typedarray).promise;
          let fullText = '';
          
          for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const content = await page.getTextContent();
            const strings = content.items.map(item => item.str);
            fullText += strings.join(' ') + '\n';
            setProcessProgress(Math.round((i / pdf.numPages) * 100));
          }
          setDocText(fullText);
          setIsProcessing(false);
        };
        reader.readAsArrayBuffer(file);
      } else if (file.type.startsWith('image/')) {
        // OCR Processing
        const worker = await window.Tesseract.createWorker({
          logger: m => {
            if (m.status === 'recognizing text') {
              setProcessProgress(Math.round(m.progress * 100));
            }
          }
        });
        await worker.loadLanguage('eng');
        await worker.initialize('eng');
        const { data: { text } } = await worker.recognize(file);
        setDocText(text);
        await worker.terminate();
        setIsProcessing(false);
      } else {
        throw new Error("Unsupported file format. Please use PDF, JPG, or PNG.");
      }
    } catch (err) {
      setError(err.message || "Failed to process the file.");
      setIsProcessing(false);
    }
  };

  const analyzeDocument = async () => {
    if (!docText.trim()) return;
    if (!apiKey) {
      setError("Please set your Gemini API Key in the settings first.");
      setShowKeyInput(true);
      return;
    }

    setIsAnalyzing(true);
    setError(null);

    const systemPrompt = `
      You are a specialized Legal Document Auditor. 
      Analyze the document for the following specific items and provide a JSON response:
      1. Mandatory Clauses: (Parties, Date, Termination, Governing Law).
      2. Onerous Clauses: (Burdensome payment terms, unfair liability shifts).
      3. Clawback Provisions: (Recovery of paid bonuses/fees).
      4. Prohibited/Restrictive: (Illegal non-competes, restraint of trade).
      
      Response format MUST be JSON:
      {
        "score": number,
        "summary": "string",
        "clauses": [{"name": "string", "found": boolean, "excerpt": "string or null"}],
        "risks": [{"level": "High|Medium|Low", "type": "Onerous|Clawback|Prohibited|General", "description": "string", "remedy": "string"}]
      }
    `;

    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: `Validate this text:\n\n${docText}` }] }],
          systemInstruction: { parts: [{ text: systemPrompt }] },
          generationConfig: { responseMimeType: "application/json" }
        })
      });

      if (!response.ok) throw new Error("API call failed.");

      const data = await response.json();
      const textResponse = data.candidates?.[0]?.content?.parts?.[0]?.text;
      setResults(JSON.parse(textResponse || "{}"));
      setActiveTab('results');
    } catch (err) {
      setError("Analysis failed. Check your API key and network.");
    } finally {
      setIsAnalyzing(false);
    }
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-900 font-sans p-4 md:p-8">
      <div className="max-w-5xl mx-auto">
        <header className="flex items-center justify-between mb-8">
          <div className="flex items-center gap-3">
            <div className="bg-indigo-600 p-2 rounded-lg"><Scale className="text-white w-8 h-8" /></div>
            <div>
              <h1 className="text-2xl font-bold tracking-tight">LexVerify AI</h1>
              <p className="text-slate-500 text-sm font-medium flex items-center gap-2">
                Legal Auditor <span className="text-[10px] bg-indigo-100 text-indigo-700 px-1.5 py-0.5 rounded font-black tracking-widest uppercase">PRO v3.0</span>
              </p>
            </div>
          </div>
          <button onClick={() => setShowKeyInput(!showKeyInput)} className={`p-2 rounded-full transition-all ${apiKey ? 'text-indigo-600 bg-indigo-50' : 'text-amber-600 bg-amber-50 animate-pulse'}`}>
            <Settings className="w-6 h-6" />
          </button>
        </header>

        {showKeyInput && (
          <div className="mb-6 bg-white p-6 rounded-2xl border-2 border-indigo-100 shadow-xl animate-in slide-in-from-top-4">
            <div className="flex items-center gap-2 mb-4 font-bold text-slate-800"><Key className="w-5 h-5 text-indigo-600" /> API Configuration</div>
            <div className="flex gap-2">
              <input type="password" value={apiKey} onChange={(e) => setApiKey(e.target.value)} placeholder="Gemini API Key..." className="flex-1 px-4 py-2 border border-slate-200 rounded-xl outline-none font-mono text-sm" />
              <button onClick={() => saveApiKey(apiKey)} className="bg-indigo-600 text-white px-6 py-2 rounded-xl font-bold">Save</button>
            </div>
          </div>
        )}

        <div className="flex gap-1 bg-slate-200/50 p-1 rounded-xl mb-6 w-fit">
          <button onClick={() => setActiveTab('upload')} className={`px-4 py-2 rounded-lg text-sm font-semibold transition-all ${activeTab === 'upload' ? 'bg-white shadow-sm text-indigo-600' : 'text-slate-600'}`}>1. Document Input</button>
          <button disabled={!results} onClick={() => setActiveTab('results')} className={`px-4 py-2 rounded-lg text-sm font-semibold transition-all ${activeTab === 'results' ? 'bg-white shadow-sm text-indigo-600' : 'text-slate-400'}`}>2. Analysis Results</button>
        </div>

        <main className="grid grid-cols-1 gap-6">
          {activeTab === 'upload' && (
            <div className="space-y-6">
              {/* Input Methods */}
              <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div className="md:col-span-1 bg-white p-6 rounded-2xl border border-slate-200 shadow-sm flex flex-col items-center text-center">
                  <div className="bg-indigo-50 p-3 rounded-full mb-3"><FileCode className="text-indigo-600 w-6 h-6" /></div>
                  <h3 className="font-bold text-slate-800 text-sm mb-1">Upload File</h3>
                  <p className="text-[10px] text-slate-500 mb-4">PDF, PNG, JPG</p>
                  <input type="file" hidden ref={fileInputRef} onChange={handleFileUpload} accept=".pdf,image/*" />
                  <button 
                    onClick={() => fileInputRef.current?.click()}
                    disabled={isProcessing}
                    className="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded-xl text-xs font-bold flex items-center justify-center gap-2 transition-all shadow-md shadow-indigo-100"
                  >
                    {isProcessing ? <Loader2 className="w-3 h-3 animate-spin" /> : <Upload className="w-3 h-3" />}
                    {isProcessing ? `${processProgress}%` : "Choose"}
                  </button>
                </div>
                
                <div className="md:col-span-3 bg-white p-4 rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                  <div className="flex items-center gap-2 mb-3 px-2 font-bold text-[10px] text-slate-400 uppercase tracking-widest"><BookOpen className="w-3 h-3" /> Sample Library</div>
                  <div className="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    {SAMPLES.map((s, i) => (
                      <button key={i} onClick={() => setDocText(s.text)} className="text-left p-3 rounded-xl border border-slate-50 hover:bg-indigo-50/50 hover:border-indigo-100 transition-all text-xs group">
                        <div className="flex justify-between items-center mb-1">
                          <span className="font-bold text-slate-800">{s.title}</span>
                          <span className="text-[9px] bg-slate-100 px-1.5 py-0.5 rounded group-hover:bg-white">{s.type}</span>
                        </div>
                        <p className="text-[10px] text-slate-400 line-clamp-1 italic">Click to load into editor...</p>
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              {/* Text Area */}
              <div className="bg-white rounded-2xl shadow-xl border border-slate-200 overflow-hidden">
                <div className="p-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/30">
                  <div className="flex items-center gap-2 font-bold text-slate-700 text-sm"><Type className="w-4 h-4 text-indigo-500" /> Document Content Editor</div>
                  <button 
                    onClick={analyzeDocument} 
                    disabled={isAnalyzing || !docText.trim()} 
                    className="bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 text-white px-8 py-2 rounded-full font-bold shadow-lg transition-all flex items-center gap-2"
                  >
                    {isAnalyzing ? <Loader2 className="w-4 h-4 animate-spin" /> : <ShieldCheck className="w-4 h-4" />}
                    Validate AI Audit
                  </button>
                </div>
                <div className="p-4">
                  {isProcessing && (
                    <div className="mb-4 bg-indigo-50 border border-indigo-100 p-4 rounded-xl">
                      <div className="flex justify-between mb-2">
                        <span className="text-xs font-bold text-indigo-700 flex items-center gap-2">
                          <Loader2 className="w-3 h-3 animate-spin" /> Processing document content...
                        </span>
                        <span className="text-xs font-bold text-indigo-700">{processProgress}%</span>
                      </div>
                      <div className="w-full bg-indigo-200 h-1 rounded-full overflow-hidden">
                        <div className="bg-indigo-600 h-full transition-all duration-300" style={{ width: `${processProgress}%` }} />
                      </div>
                    </div>
                  )}
                  <textarea value={docText} onChange={(e) => setDocText(e.target.value)} placeholder="Paste text here or upload a document to begin..." className="w-full h-80 p-4 bg-slate-50 border border-slate-200 rounded-xl focus:ring-4 focus:ring-indigo-100 outline-none font-mono text-sm resize-none" />
                  {error && (
                    <div className="mt-4 p-4 bg-red-50 text-red-700 text-xs rounded-xl border border-red-100 font-bold flex items-center gap-2">
                      <XCircle className="w-4 h-4" /> {error}
                    </div>
                  )}
                </div>
              </div>
            </div>
          )}

          {activeTab === 'results' && results && (
            <div className="space-y-6 animate-in slide-in-from-bottom-4">
              <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col justify-center items-center text-center">
                  <p className="text-slate-500 text-[10px] font-black uppercase mb-2 tracking-widest">Compliance Score</p>
                  <span className={`text-6xl font-black ${results.score > 70 ? 'text-emerald-500' : 'text-red-500'}`}>{results.score}%</span>
                </div>
                <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 md:col-span-2">
                  <p className="text-slate-500 text-[10px] font-black uppercase mb-2 tracking-widest">Legal Expert Summary</p>
                  <p className="text-slate-700 font-medium leading-relaxed">{results.summary}</p>
                </div>
              </div>

              {/* Mandatory Clause Check */}
              <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div className="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                  <h3 className="font-bold flex items-center gap-2 text-slate-700"><Search className="w-4 h-4 text-indigo-500" /> Structure Check</h3>
                </div>
                <div className="divide-y divide-slate-100">
                  {results.clauses.map((clause, idx) => (
                    <div key={idx} className="p-4 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                      <div className="flex items-center gap-3">
                        {clause.found ? <CheckCircle className="w-5 h-5 text-emerald-500" /> : <XCircle className="w-5 h-5 text-red-400" />}
                        <span className="font-bold text-slate-700 text-sm">{clause.name}</span>
                      </div>
                      {!clause.found && <span className="text-[10px] font-bold text-red-500 uppercase px-2 py-0.5 bg-red-50 rounded">Missing</span>}
                    </div>
                  ))}
                </div>
              </div>

              {/* Risk Flags */}
              <div className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div className="px-6 py-4 border-b border-slate-100 bg-red-50/30 flex items-center justify-between">
                  <h3 className="font-bold flex items-center gap-2 text-red-800"><AlertTriangle className="w-4 h-4" /> Detected Risk Redlines</h3>
                  <span className="text-[10px] font-bold bg-red-100 text-red-700 px-2 py-1 rounded-full uppercase">{results.risks.length} Flags</span>
                </div>
                <div className="p-0 divide-y divide-slate-100">
                  {results.risks.length > 0 ? results.risks.map((risk, idx) => (
                    <div key={idx} className="p-6 hover:bg-slate-50/50 transition-colors">
                      <div className="flex items-center gap-2 mb-2">
                        <span className={`text-[9px] font-black px-2 py-0.5 rounded-md uppercase ${risk.level === 'High' ? 'bg-red-600 text-white' : 'bg-amber-400 text-white'}`}>{risk.level} Severity</span>
                        <span className="text-[10px] font-bold text-slate-400 uppercase tracking-tighter ml-2">{risk.type}</span>
                      </div>
                      <h4 className="font-bold text-slate-800 text-lg mb-1">{risk.description}</h4>
                      <div className="flex items-start gap-2 mt-3 p-4 bg-emerald-50 rounded-xl border border-emerald-100">
                        <Info className="w-4 h-4 text-emerald-600 mt-0.5 flex-shrink-0" />
                        <p className="text-sm text-emerald-900 font-medium">
                          <span className="font-bold uppercase text-[9px] bg-emerald-100 px-1.5 py-0.5 rounded text-emerald-700 mr-2">Proposed Remedy</span>
                          {risk.remedy}
                        </p>
                      </div>
                    </div>
                  )) : (
                    <div className="p-10 text-center">
                      <CheckCircle className="w-12 h-12 text-emerald-500 mx-auto mb-3" />
                      <p className="text-slate-500 font-bold">Document content appears to be low risk.</p>
                    </div>
                  )}
                </div>
              </div>
              
              <div className="flex justify-center py-4">
                <button onClick={() => setActiveTab('upload')} className="text-slate-400 hover:text-indigo-600 font-bold text-sm transition-all flex items-center gap-2">
                  <ChevronRight className="w-4 h-4 rotate-180" /> Back to Document Editor
                </button>
              </div>
            </div>
          )}
        </main>
      </div>
    </div>
  );
};

export default App;
